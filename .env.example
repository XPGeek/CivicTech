# DMV Water Watch — environment variables
#
# Copy this file to `.env.local` for Next.js dev (`npm run dev`)
# and `.env` for connector/pipeline scripts. Only the public-prefixed
# variables are read by the browser bundle.

# Where the frontend reads its data from.
#   local   — read JSON from data/snapshots/dev/ (recommended for development)
#   remote  — read JSON from NEXT_PUBLIC_R2_BASE_URL (used in production)
NEXT_PUBLIC_DATA_SOURCE=local

# Base URL of the deployed R2 bucket (or any CDN serving the build artifacts).
# Required only when NEXT_PUBLIC_DATA_SOURCE=remote.
# Example: https://data.dmv-water-watch.example.com
NEXT_PUBLIC_R2_BASE_URL=

# Map tile source.
#   osm-raster  — OpenStreetMap raster tiles (default, no token needed)
#   mapbox      — Mapbox Standard vector style (requires NEXT_PUBLIC_MAPBOX_TOKEN)
NEXT_PUBLIC_MAP_STYLE=osm-raster

# Mapbox token. Required only when NEXT_PUBLIC_MAP_STYLE=mapbox.
# URL-restrict the token to your production and preview domains.
NEXT_PUBLIC_MAPBOX_TOKEN=

# User-Agent header sent by connectors (NOAA api.weather.gov requires identification).
# Format recommendation: "dmv-water-watch (your-contact@example.com)"
CONNECTOR_USER_AGENT=dmv-water-watch (contact@example.org)

# Sentry DSN for browser error capture. When unset, errors are logged to the
# console and the error boundary still works — Sentry is a drop-in upgrade.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: write build artifacts to R2 instead of data/snapshots/dev/.
# When all four are set, the pipeline uploads via the S3-compatible API.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
